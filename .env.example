# Required: GitHub token used by server-side analysis
GITHUB_TOKEN=your_github_token
# Alternative key supported by the app:
# GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token

# Required: AI provider key used for feedback generation
AI_API_KEY=your_gemini_api_key
# Alternative key supported by the app:
# GEMINI_API_KEY=your_gemini_api_key

# Optional: choose model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: distributed storage for rate limit + AI cache
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
# Or Upstash naming:
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...

# Optional: request protection tuning
# ANALYZE_RATE_LIMIT_PER_MINUTE=5
# ANALYZE_RATE_LIMIT_PER_DAY=50
# ANALYZE_COOLDOWN_MS=5000
# ANALYZE_COOLDOWN_MAX_ENTRIES=10000

# Optional: AI cache tuning
# ANALYZE_AI_CACHE_TTL_MS=3600000
# ANALYZE_AI_CACHE_MAX_ENTRIES=2000
# ANALYZE_AI_PROMPT_VERSION=v4